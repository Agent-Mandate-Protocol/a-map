{
  "name": "@agentmandateprotocol/middleware",
  "version": "1.0.1",
  "description": "A-MAP request verification middleware for Express, Hono, and fetch — drop-in agent authorization",
  "license": "MIT",
  "author": "Agent Mandate Protocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentmandateprotocol/core": "workspace:*"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "hono": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "*",
    "vitest": "*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
